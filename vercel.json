{
  "crons": [
    {
      "path": "/api/cron/process",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/shadow-audit",
      "schedule": "0 0 * * 1"
    },
    {
      "path": "/api/cron/generate-top5",
      "schedule": "0 10 * * *"
    }
  ],
  "functions": {
    "app/api/cron/process/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/generate-top5/route.ts": {
      "maxDuration": 60
    }
  }
}
